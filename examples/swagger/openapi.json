{
  "openapi": "3.0.3",
  "info": {
    "title": "Orders API",
    "description": "Example API hosted by shost with a bundled Swagger UI.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/orders": {
      "get": {
        "summary": "List orders",
        "operationId": "listOrders",
        "responses": {
          "200": {
            "description": "The current orders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Order" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "status": { "type": "string", "enum": ["pending", "shipped"] }
        }
      }
    }
  }
}
